rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isAdmin() {
      return request.auth.token.email in [
        'admin@posthire.in',
        'superadmin@posthire.in'
      ];
    }

    // USERS — only owner or admin
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // CREATORS — all logged-in can read, only owner/admin can write
    match /creators/{uid} {
      allow read:   if isLoggedIn();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // FOUNDERS — same as creators
    match /founders/{uid} {
      allow read:   if isLoggedIn();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // REQUESTS — logged-in can read/create/update, only admin can delete
    match /requests/{requestId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // ADMIN BROADCASTS — logged-in read, admin write
    match /admin_broadcasts/{id} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ADMIN SETTINGS — admin only
    match /admin_settings/{docId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // META (seed flag) — logged-in read/write
    match /_meta/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isLoggedIn();
    }
  }
}
